# Copy to .env.local for local dev, or set in Railway → frontend service → Variables

# Backend API (required at build time for production — Railway rebuilds after changing this)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Clerk (optional — app works without auth if unset)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
